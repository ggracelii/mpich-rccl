#!/bin/bash
#SBATCH -A csc678
#SBATCH -J csel-confirm
#SBATCH -t 00:10:00
#SBATCH --network=single_node_vni
#SBATCH -o %x-%j.out
#
# Targeted crossover confirmation (staged-CPU/alpha vs RCCL) around a candidate
# cutoff. Submit via submit_csel_confirm.sh, which supplies per-node-count env:
#   PROBE_SPLIT  - alpha/beta split + swap size + mpir ccl gate (set ABOVE the
#                  suspected crossover so alpha is measured through the bracket)
#   MRANGE       - OSU -m lo:hi window around the bracket
#   JSON_CH4_P / JSON_MPIR_P - per-N probe JSONs (generated by the submit script)
# Only two curves are needed: HYBRID (alpha through the window) and RCCL.

set -o pipefail
HERE=${FRONTIER_HOME:-${SLURM_SUBMIT_DIR:-$(cd "$(dirname "$0")" && pwd)}}
[ -f "$HERE/env.sh" ] || { echo "FATAL: env.sh not found in '$HERE'" >&2; exit 1; }
source "$HERE/env.sh"
: "${WORK:?}"; : "${PROBE_SPLIT:?}"; : "${MRANGE:?}"; : "${JSON_CH4_P:?}"; : "${JSON_MPIR_P:?}"
[ -f "$JSON_CH4_P" ] && [ -f "$JSON_MPIR_P" ] || { echo "FATAL: probe JSONs missing ($JSON_CH4_P / $JSON_MPIR_P)" >&2; exit 1; }
BIND="$HERE/bind_frontier.sh"

NODES=${SLURM_JOB_NUM_NODES:?}
PPN=8; NRANKS=$((NODES * PPN))
ARGS="-m $MRANGE -i 30 -x 10 -d rocm -f"

RESULTS=$WORK/results_csel_confirm/N${NODES}_job${SLURM_JOB_ID}
mkdir -p "$RESULTS"
{ echo "nodes=$NODES split=$PROBE_SPLIT mrange=$MRANGE"; module list; } > "$RESULTS/env.txt" 2>&1
cp "$JSON_CH4_P" "$JSON_MPIR_P" "$RESULTS/"

load_mine
module load rccl-net-plugin
MPIEXEC="mpiexec -bootstrap slurm -n $NRANKS -ppn $PPN -bind-to numa"
OSU_MINE_BIN=$OSU_MINE/libexec/osu-micro-benchmarks/mpi/collective/osu_allreduce

echo "=== HYBRID (alpha<=$PROBE_SPLIT) ===" | tee "$RESULTS/HYBRID.txt"
MPIR_CVAR_DEVICE_COLLECTIVES=all \
MPIR_CVAR_CH4_GPU_COLL_SWAP_BUFFER_SZ=$PROBE_SPLIT \
MPIR_CVAR_CH4_COLL_SELECTION_TUNING_JSON_FILE="$JSON_CH4_P" \
MPIR_CVAR_CH4_COLL_SELECTION_TUNING_JSON_FILE_GPU="$JSON_CH4_P" \
MPIR_CVAR_COLL_SELECTION_TUNING_JSON_FILE="$JSON_MPIR_P" \
  $MPIEXEC "$BIND" "$OSU_MINE_BIN" $ARGS 2>&1 | tee -a "$RESULTS/HYBRID.txt" || true

echo "=== RCCL ===" | tee "$RESULTS/RCCL.txt"
MPIR_CVAR_ALLREDUCE_INTRA_ALGORITHM=ccl MPIR_CVAR_ALLREDUCE_CCL=rccl MPIR_CVAR_DEVICE_COLLECTIVES=none \
  $MPIEXEC "$BIND" "$OSU_MINE_BIN" $ARGS 2>&1 | tee -a "$RESULTS/RCCL.txt" || true

echo "[confirm] done -> $RESULTS"
